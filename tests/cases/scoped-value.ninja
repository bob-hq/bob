# This file was automatically generated by Bob.
builddir = build/.bob
build build/.bob/always: phony

rule bob-1
  command = echo $magic > $out

build build/hi: bob-1
  magic = hi
rule bob-2
  command = echo $magic $magic > $out

build build/hi$ hi: bob-2
  magic = hi
rule configure-bob-3
  command = FORCE_COLOR=1 $bobbin configure --use-current-configs -f $bobfile
  description = CONFIGURE $out
  generator = 1
  pool = console

build build/.bob/build.ninja: configure-bob-3 | $root/tests/cases/scoped-value.bob build/.bob/configs.json
  bobbin = $root/.venv/bin/python -m bob
  bobfile = $root/tests/cases/scoped-value.bob
